# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).

# --- Pinecone (managed vector store) ---
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX=qiskit-documentation

# --- Cohere (used only for query-time reranking now; optional) ---
COHERE_API_KEY=your-cohere-key

# --- Generation LLM keys (set the one matching LLM_PROVIDER below) ---
GEMINI_API_KEY=your-gemini-key
# Anthropic Developer Platform key (platform.claude.com) — billed separately from a
# Claude Max subscription; Max does NOT grant API usage.
ANTHROPIC_API_KEY=your-anthropic-key

# --- Embeddings ---
EMBEDDING_PROVIDER=local                  # local (BGE on GPU/CPU) | cohere
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5     # local model (1024-d); for cohere use COHERE_EMBEDDING_MODEL
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=                          # blank = auto (cuda if available, else cpu)
EMBEDDING_BATCH_SIZE=64
COHERE_EMBEDDING_MODEL=embed-english-v3.0  # only used when EMBEDDING_PROVIDER=cohere

# --- Reranking (query-time; uses Cohere if enabled + key present, else skipped) ---
RERANK_ENABLED=true
RERANK_MODEL=rerank-english-v3.0

# --- Generation ---
LLM_PROVIDER=ollama              # gemini | anthropic | ollama (local, free) | openai (compatible)
GEMINI_MODEL=gemini-2.5-flash    # gemini-2.5-pro requires a paid tier (free tier = 0)
ANTHROPIC_MODEL=claude-sonnet-4-6
OLLAMA_MODEL=qwen2.5-coder:7b    # local; run `ollama pull qwen2.5-coder:7b` first
OLLAMA_BASE_URL=http://localhost:11434

# --- OpenAI-compatible provider (LLM_PROVIDER=openai) ---
# One driver for any OpenAI-API endpoint; several have a FREE tier. Pick a tool/function-
# calling-capable model so structured output works. Set base_url + key + model, then
# `LLM_PROVIDER=openai`. Examples (uncomment ONE), as of 2026 — verify current free limits:
#   Groq (free, fast):     OPENAI_BASE_URL=https://api.groq.com/openai/v1          OPENAI_MODEL=llama-3.3-70b-versatile
#   Cerebras (free, fast): OPENAI_BASE_URL=https://api.cerebras.ai/v1              OPENAI_MODEL=llama-3.3-70b
#   OpenRouter (free):     OPENAI_BASE_URL=https://openrouter.ai/api/v1           OPENAI_MODEL=qwen/qwen3-coder:free
#   GitHub Models (free):  OPENAI_BASE_URL=https://models.github.ai/inference     OPENAI_MODEL=openai/gpt-4o
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_STRUCTURED_METHOD=function_calling   # function_calling | json_schema | json_mode

# --- Infra ---
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=sqlite:///app.db

# --- Migration / RAG params ---
QISKIT_TARGET_VERSION=2.2
RETRIEVAL_TOP_K=12
RERANK_TOP_N=6
MAX_INPUT_CHARS=20000
MAX_REPAIRS=2

# --- Sandbox (executable validation of ported code) ---
SANDBOX_BACKEND=none                              # none | local | docker
SANDBOX_TIMEOUT_S=30
SANDBOX_IMAGE=qiskit-migration-sandbox:latest     # built from Dockerfile.sandbox (target Qiskit 2.x)

# --- Behavioral-equivalence check (old-on-old vs new-on-new; see equivalence.py) ---
EQUIVALENCE_ENABLED=false                                  # run inline in the transformer (adds 2 Docker runs)
LEGACY_SANDBOX_IMAGE=qiskit-migration-sandbox-legacy:latest # built from Dockerfile.sandbox-legacy (Qiskit 0.46.3)
EQUIVALENCE_FIDELITY_THRESHOLD=0.999                       # |<psi_old|psi_new>| above this counts as equivalent
EQUIVALENCE_MAX_QUBITS=12                                  # cap statevector size (2**n) compared per circuit

# --- Observability (optional: LangSmith tracing) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=qiskit-migration
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

LOG_LEVEL=INFO
